  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Dear Rob & Heist,


    my source revealed that the Old Wizard has developed
    some new hats enchanted with gravity spells. They would definitely come in handy
    in future jobs, so I would like to task you with retrieving them from his house,
    without him noticing of course.


    We can drop you in from the roof, but then
    you''ll have to find your own way out through that weird ass house.


    Please,
    do not bicker for once and cooperate,


    your little sister Takia'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2536ce360b4121d4e99568bd88389b30, type: 2}
